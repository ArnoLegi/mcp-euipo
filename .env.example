# Identifiants OAuth2 EUIPO (flow client_credentials, scope « uid »).
# Obtenus sur le portail développeur de l'EUIPO (https://dev.euipo.europa.eu/).
EUIPO_CLIENT_ID=votre_client_id
EUIPO_CLIENT_SECRET=votre_client_secret

# Optionnel : port d'écoute du serveur (défaut 8000 ; Railway fournit PORT).
# PORT=8000
